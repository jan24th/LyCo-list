# AWS profile used by SST deployments
AWS_PROFILE=lyco-list-sst

# Base domain for custom domains in deployed stages (prod / acc)
# Copy this file to .env, .env.prod, or .env.acc and fill in the actual value.
# prod: api.<BASE_DOMAIN> / app.<BASE_DOMAIN>
# acc:  api.acc.<BASE_DOMAIN> / app.acc.<BASE_DOMAIN>
# dev:  no custom domain is bound
BASE_DOMAIN=jan24th.today
