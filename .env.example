# AWS profile used by SST deployments
AWS_PROFILE=lyco-list-sst

# Base domain for custom domains in deployed stages (prod / acc)
# Copy this file to .env, .env.prod, or .env.acc and fill in the actual value.
# prod: api.<BASE_DOMAIN> / app.<BASE_DOMAIN>
# acc:  api.acc.<BASE_DOMAIN> / app.acc.<BASE_DOMAIN>
# dev:  no custom domain is bound
BASE_DOMAIN=jan24th.today

# Bruno API authorization token is managed as the `accessToken` secret variable
# in bruno/lyco-list/environments/*.bru (set locally in the Bruno client, not committed).

# Frontend environment variables injected by SST at build time
# Local development does not need to set these manually.
VITE_API_URL=
VITE_USER_POOL_ID=
VITE_USER_POOL_CLIENT_ID=
VITE_COGNITO_DOMAIN=
